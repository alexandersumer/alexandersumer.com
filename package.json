{
  "name": "alexandersumer.com",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "lint": "prettier --write .",
    "lint:check": "prettier --check .",
    "check": "astro check",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run",
    "test:browser": "npm run build && playwright test",
    "verify": "npm run check && npm test && npm run test:browser",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "cheerio": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,astro,css,md,json,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.9.0"
    }
  }
}
