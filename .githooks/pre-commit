#!/bin/sh
set -e

# Format only staged files, then re-stage them
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|astro|css|md|json|yml|yaml)$' || true)
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs ./node_modules/.bin/prettier --write
  echo "$STAGED" | xargs git add
fi

# Full CI: build (type-checks) + all tests
npm run build
npm test
