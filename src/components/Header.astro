---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__left">
    <div class="site-header__title">
      <a href="/">Alexander Sumer</a>
    </div>
    <nav class="site-header__nav">
      <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Home</a>
      <a href="/blog" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
      <a href="/slides" aria-current={currentPath.startsWith('/slides') ? 'page' : undefined}
        >Slides</a
      >
    </nav>
  </div>
  <button class="theme-toggle" type="button" id="theme-toggle" aria-label="Toggle theme"> </button>
</header>

<script>
  import { updateThemeButton, toggleTheme } from '../utils/theme';

  let controller: AbortController | null = null;

  function initThemeToggle() {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    updateThemeButton(btn);

    btn.addEventListener(
      'click',
      () => {
        toggleTheme();
        updateThemeButton(btn);
      },
      { signal }
    );

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener(
      'change',
      (e) => {
        if (!localStorage.getItem('theme')) {
          document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
          updateThemeButton(btn);
        }
      },
      { signal }
    );
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
