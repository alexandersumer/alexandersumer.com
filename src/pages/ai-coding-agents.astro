---
import '@fontsource-variable/inter';
import '@fontsource-variable/lora';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>How to Use AI Coding Agents Effectively</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var t =
          s === 'dark' || s === 'light'
            ? s
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <div id="progress"></div>

    <div id="deck">
      <!-- 1 · Title -->
      <section class="slide slide--center active">
        <div class="slide__inner">
          <h1 class="title" data-reveal style="--d:0">How to Use AI Coding Agents Effectively</h1>
        </div>
      </section>

      <!-- 2 · The problem -->
      <section class="slide slide--center">
        <div class="slide__inner">
          <blockquote class="big-quote" data-reveal style="--d:0">
            Many people use coding agents for a bit, get frustrated, and conclude "they're not
            good."
          </blockquote>
          <p class="slide__sub" data-reveal style="--d:1">
            That's like picking up a guitar, fumbling through a few chords, and concluding guitars
            don't work.
          </p>
        </div>
      </section>

      <!-- 3 · The insight -->
      <section class="slide slide--center">
        <div class="slide__inner">
          <p class="hero-text" data-reveal style="--d:0">
            The people getting the most out of agents <strong class="accent"
              >aren't using better tools.</strong
            >
          </p>
          <p class="hero-text" data-reveal style="--d:1">
            They built the <strong class="accent">skill</strong> to use them well.
          </p>
        </div>
      </section>

      <!-- 4 · The framework -->
      <section class="slide slide--center">
        <div class="slide__inner">
          <div class="framework">
            <span class="framework__word" data-reveal style="--d:0">Plan</span>
            <span class="framework__dot" data-reveal style="--d:1">&middot;</span>
            <span class="framework__word" data-reveal style="--d:2">Execute</span>
            <span class="framework__dot" data-reveal style="--d:3">&middot;</span>
            <span class="framework__word" data-reveal style="--d:4">Verify</span>
          </div>
          <p class="slide__sub" data-reveal style="--d:5">
            Three fundamentally different activities. Keep them separate.
          </p>
        </div>
      </section>

      <!-- 5 · Plan your sessions -->
      <section class="slide" data-section="planning">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Planning</span>
          <h2 class="heading" data-reveal style="--d:1">Plan your sessions</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>Break your task into a sequence of prompts, executed one by one</li>
            <li>Each chunk small enough that the agent handles it within context</li>
            <li>Anti-pattern: stuffing all requirements into one prompt</li>
            <li>
              <em>"The result feels like 10 devs worked on it without talking to each other"</em>
            </li>
          </ul>
        </div>
      </section>

      <!-- 6 · Front-load context -->
      <section class="slide" data-section="planning">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Planning</span>
          <h2 class="heading" data-reveal style="--d:1">Context before code</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>First: read the README, understand the test framework, reproduce the problem</li>
            <li>Lead with constraints and context, not implementation details</li>
            <li>All context up front is fine if it's reasoning about the plan, not executing</li>
          </ul>
        </div>
      </section>

      <!-- 7 · Parallelize -->
      <section class="slide" data-section="execution">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Execution</span>
          <h2 class="heading" data-reveal style="--d:1">Parallelize your sessions</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>Create multiple <strong>full clones</strong> of your repo, not worktrees</li>
            <li>Each session has its own context window</li>
            <li>Three parallel sessions = triple your total context budget</li>
            <li>One concern per session</li>
          </ul>
        </div>
      </section>

      <!-- 8 · Smartest models -->
      <section class="slide" data-section="execution">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Execution</span>
          <h2 class="heading" data-reveal style="--d:1">Smarter models are cheaper</h2>
          <blockquote class="slide-quote" data-reveal style="--d:2">
            "A $0.50 prompt that gets it right in one shot is cheaper than five $0.05 prompts that
            each need fixing."
          </blockquote>
          <p class="slide__note" data-reveal style="--d:3">
            Don't optimize for token cost when the bottleneck is your time.
          </p>
        </div>
      </section>

      <!-- 9 · Context window -->
      <section class="slide" data-section="execution">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Execution</span>
          <h2 class="heading" data-reveal style="--d:1">Manage your context window</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>LLMs perform <strong>measurably worse</strong> as the context fills</li>
            <li>Compact or summarize at 50%</li>
            <li>At 70%, start fresh</li>
            <li>New sessions for new tasks. Don't reuse a debugging session for feature work.</li>
          </ul>
        </div>
      </section>

      <!-- 10 · Verification step -->
      <section class="slide" data-section="verification">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Verification</span>
          <h2 class="heading" data-reveal style="--d:1">
            Tell the agent how to verify its own work
          </h2>
          <blockquote class="slide-quote" data-reveal style="--d:2">
            "After refactoring, write a script to check that only test cases calling suspending
            methods got runTest added and no annotations were removed."
          </blockquote>
          <p class="slide__note" data-reveal style="--d:3">
            Automated and deterministic. Not "look at the code and tell me if it's right."
          </p>
        </div>
      </section>

      <!-- 11 · Test-first -->
      <section class="slide slide--center" data-section="verification">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Verification</span>
          <p class="hero-text" data-reveal style="--d:1">
            A test that has never failed is a test you cannot trust.
          </p>
          <p class="slide__sub" data-reveal style="--d:2">
            "A smoke detector that has never been near smoke tells you nothing about whether it
            works."
          </p>
          <p class="slide__note" data-reveal style="--d:3">
            Write the test first. Run it. Watch it fail. Then implement.
          </p>
        </div>
      </section>

      <!-- 12 · Dev loop -->
      <section class="slide" data-section="verification">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Verification</span>
          <h2 class="heading" data-reveal style="--d:1">Invest in your local dev loop</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>Your agent is only as good as your feedback loop</li>
            <li>Reproduce CI locally, run the service e2e locally</li>
            <li>Fast local feedback: lint, type check, unit tests, e2e, security scan</li>
            <li>If CI takes 20 minutes remotely, you're flying blind for 20 minutes</li>
          </ul>
        </div>
      </section>

      <!-- 13 · Security stat -->
      <section class="slide slide--center" data-section="verification">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Verification</span>
          <p class="stat" data-reveal style="--d:1">87%</p>
          <h2 class="stat-heading" data-reveal style="--d:2">
            of agent PRs contained at least one security vulnerability.
          </h2>
          <p class="slide__note" data-reveal style="--d:3">
            Every PR was functional. The code worked. It wasn't secure.<br />Add security scanning
            to your verification loop.
          </p>
        </div>
      </section>

      <!-- 14 · Automate rules -->
      <section class="slide" data-section="verification">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Verification</span>
          <h2 class="heading" data-reveal style="--d:1">
            Don't rely on the model to remember your rules
          </h2>
          <blockquote class="slide-quote" data-reveal style="--d:2">
            "An instruction in your project file saying 'never use rm -rf' can get ignored. An
            automated rule that blocks it cannot."
          </blockquote>
          <p class="slide__note" data-reveal style="--d:3">
            Hooks, pre-commit checks, automated guardrails. Enforce them with automation.
          </p>
        </div>
      </section>

      <!-- 15 · Bail -->
      <section class="slide" data-section="meta">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Meta-Skills</span>
          <h2 class="heading" data-reveal style="--d:1">Know when to bail</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>
              <strong>Context corruption is irreversible.</strong> Failed attempts confuse every subsequent
              turn.
            </li>
            <li>Start a clean session. It takes 30 seconds.</li>
            <li>
              Bail signals: repeats itself, contradicts earlier decisions, suggests rejected fixes
            </li>
          </ul>
        </div>
      </section>

      <!-- 16 · Commit -->
      <section class="slide" data-section="meta">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Meta-Skills</span>
          <h2 class="heading" data-reveal style="--d:1">Commit before everything</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>Agents move fast and break things across many files at once</li>
            <li>Commit before every major agent operation</li>
            <li><code>git diff</code> between commits is the fastest way to review</li>
            <li>Small commits let you revert a single bad step instead of an entire session</li>
          </ul>
        </div>
      </section>

      <!-- 17 · Languages -->
      <section class="slide" data-section="meta">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Meta-Skills</span>
          <h2 class="heading" data-reveal style="--d:1">Work in agent-friendly languages</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>
              <strong>Static types:</strong> compiler-driven feedback loop at every edit
            </li>
            <li>
              <strong>Source-available packages:</strong> the agent reads actual library code, not docs
            </li>
            <li><strong>Popularity:</strong> training data volume</li>
            <li>
              You need all three together. Today that's <strong class="accent">TypeScript</strong> and
              <strong class="accent">Go</strong>.
            </li>
          </ul>
        </div>
      </section>

      <!-- 18 · Expert amplifier -->
      <section class="slide slide--center" data-section="meta">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Meta-Skills</span>
          <p class="hero-text" data-reveal style="--d:1">
            The agent does the typing.<br />The human does the <strong class="accent"
              >judgment.</strong
            >
          </p>
          <p class="slide__sub" data-reveal style="--d:2">
            "An agent refactors your database access layer. It compiles, passes tests, looks clean.
            A senior engineer sees it opens a new connection per query instead of using the pool."
          </p>
        </div>
      </section>

      <!-- 19 · Limits -->
      <section class="slide" data-section="meta">
        <div class="slide__inner">
          <span class="label" data-reveal style="--d:0">Meta-Skills</span>
          <h2 class="heading" data-reveal style="--d:1">Know when NOT to use agents</h2>
          <ul class="points" data-reveal style="--d:2">
            <li>Bad at work requiring large amounts of subtle context over many steps</li>
            <li>Bad when the cost of a wrong answer is high and verification is hard</li>
            <li>
              Agents are confident and fast. If you can't verify quickly, that confidence works
              against you.
            </li>
          </ul>
        </div>
      </section>

      <!-- 20 · End -->
      <section class="slide slide--center slide--end">
        <div class="slide__inner">
          <p class="end-text" data-reveal style="--d:0">Read the full post</p>
          <a
            class="end-link"
            href="/blog/how-to-use-ai-coding-agents-effectively"
            data-reveal
            style="--d:1">alexandersumer.com/blog/how-to-use-ai-coding-agents-effectively</a
          >
        </div>
      </section>
    </div>

    <div id="counter"></div>
    <div id="hint">
      <span>Use</span>
      <kbd>&larr;</kbd>
      <kbd>&rarr;</kbd>
      <span>to navigate</span>
    </div>
  </body>
</html>

<style>
  /* ═══════════════════════════════════════
     TOKENS
     ═══════════════════════════════════════ */
  :root {
    --bg: #ffffff;
    --text: #242424;
    --text-muted: #696969;
    --text-faint: #909090;
    --heading: #000000;
    --accent: #087da1;
    --c-planning: #9a7200;
    --c-execution: #4a6fa5;
    --c-verification: #1a7a3a;
    --c-meta: #6b4fa8;
    --border: #e0e0e0;
    --code-bg: #f5f5f5;
    --vignette: rgba(0, 0, 0, 0.04);
    --font-ui: 'Inter Variable', -apple-system, system-ui, sans-serif;
    --font-body: 'Lora Variable', Charter, Georgia, serif;
  }

  [data-theme='dark'] {
    --bg: #1c1c22;
    --text: #d0d0d4;
    --text-muted: #a0a0a6;
    --text-faint: #707078;
    --heading: #e2e2e6;
    --accent: #7cc4db;
    --c-planning: #d4a633;
    --c-execution: #7ea8d6;
    --c-verification: #6dce8a;
    --c-meta: #b090e0;
    --border: #35353f;
    --code-bg: #2a2a31;
    --vignette: rgba(0, 0, 0, 0.15);
  }

  /* ═══════════════════════════════════════
     BASE
     ═══════════════════════════════════════ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    height: 100%;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    transition:
      background 0.3s ease,
      color 0.3s ease;
  }

  [data-theme='dark'] body {
    -webkit-font-smoothing: auto;
  }

  /* Vignette */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 50%, var(--vignette) 100%);
    pointer-events: none;
    z-index: 100;
  }

  /* ═══════════════════════════════════════
     PROGRESS BAR
     ═══════════════════════════════════════ */
  #progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 4px;
    background: var(--accent);
    z-index: 200;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    width: 0%;
  }

  /* ═══════════════════════════════════════
     SLIDE LAYOUT
     ═══════════════════════════════════════ */
  ::selection {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--heading);
  }

  #deck {
    position: relative;
    width: 100%;
    height: 100%;
    user-select: none;
    cursor: default;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px;
    opacity: 0;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.4s ease;
  }

  .slide__inner {
    max-width: 820px;
    width: 100%;
  }

  .slide--center .slide__inner {
    text-align: center;
  }

  /* ═══════════════════════════════════════
     REVEAL ANIMATION
     ═══════════════════════════════════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
  }

  .slide.active [data-reveal] {
    opacity: 1;
    transform: translateY(0);
    transition:
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s ease;
    transition-delay: calc(var(--d, 0) * 100ms + 250ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .slide,
    [data-reveal] {
      transition: none !important;
    }
    [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }

  /* ═══════════════════════════════════════
     TITLE SLIDE
     ═══════════════════════════════════════ */
  .title {
    font-family: var(--font-ui);
    font-size: clamp(36px, 5.5vw, 58px);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: var(--heading);
  }

  /* ═══════════════════════════════════════
     HERO TEXT
     ═══════════════════════════════════════ */
  .hero-text {
    font-family: var(--font-ui);
    font-size: clamp(24px, 3.2vw, 38px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--heading);
    margin-bottom: 8px;
  }

  .hero-text:last-of-type {
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════
     FRAMEWORK
     ═══════════════════════════════════════ */
  .framework {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .framework__word {
    font-family: var(--font-ui);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--heading);
    line-height: 1;
  }

  .framework__dot {
    font-size: clamp(32px, 5vw, 56px);
    color: var(--accent);
    line-height: 1;
    font-weight: 300;
  }

  /* ═══════════════════════════════════════
     SECTION LABEL
     ═══════════════════════════════════════ */
  .label {
    display: block;
    width: fit-content;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--lc, var(--accent));
    background: color-mix(in srgb, var(--lc, var(--accent)) 10%, transparent);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  [data-section='planning'] .label {
    --lc: var(--c-planning);
  }
  [data-section='execution'] .label {
    --lc: var(--c-execution);
  }
  [data-section='verification'] .label {
    --lc: var(--c-verification);
  }
  [data-section='meta'] .label {
    --lc: var(--c-meta);
  }

  /* ═══════════════════════════════════════
     HEADINGS
     ═══════════════════════════════════════ */
  .heading {
    font-family: var(--font-ui);
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--heading);
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════
     POINTS
     ═══════════════════════════════════════ */
  .points {
    list-style: none;
    padding: 0;
  }

  .points li {
    font-family: var(--font-ui);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 400;
    line-height: 1.6;
    color: var(--text);
    padding: 8px 0 8px 24px;
    position: relative;
  }

  .points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lc, var(--accent));
    opacity: 0.5;
  }

  .points li em {
    color: var(--text-muted);
    font-style: italic;
  }

  .points li strong {
    font-weight: 600;
    color: var(--heading);
  }

  .points li code {
    font-family: 'SF Mono', 'Fira Code', Consolas, monospace;
    font-size: 0.88em;
    background: var(--code-bg);
    padding: 2px 7px;
    border-radius: 4px;
  }

  /* ═══════════════════════════════════════
     QUOTES
     ═══════════════════════════════════════ */
  .big-quote {
    font-family: var(--font-body);
    font-size: clamp(24px, 3vw, 34px);
    font-style: italic;
    line-height: 1.5;
    color: var(--heading);
    margin-bottom: 28px;
  }

  .big-quote::before {
    content: none;
  }

  .slide-quote {
    font-family: var(--font-body);
    font-size: clamp(19px, 2.2vw, 24px);
    font-style: italic;
    line-height: 1.6;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    margin: 0 0 20px;
  }

  /* ═══════════════════════════════════════
     STAT
     ═══════════════════════════════════════ */
  .stat {
    font-family: var(--font-ui);
    font-size: clamp(80px, 16vw, 160px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .stat-heading {
    font-family: var(--font-ui);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--heading);
    margin-bottom: 20px;
  }

  /* ═══════════════════════════════════════
     SUPPORTING TEXT
     ═══════════════════════════════════════ */
  .slide__sub {
    font-family: var(--font-body);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 640px;
  }

  .slide--center .slide__sub {
    margin-left: auto;
    margin-right: auto;
  }

  .slide__note {
    font-family: var(--font-ui);
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════
     ACCENT
     ═══════════════════════════════════════ */
  .accent {
    color: var(--accent);
  }

  /* ═══════════════════════════════════════
     END SLIDE
     ═══════════════════════════════════════ */
  .end-text {
    font-family: var(--font-ui);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--heading);
    margin-bottom: 20px;
  }

  .end-link {
    font-family: var(--font-ui);
    font-size: clamp(15px, 1.6vw, 18px);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    padding-bottom: 2px;
    transition: border-color 0.2s ease;
    cursor: pointer;
    user-select: text;
  }

  .end-link:hover {
    border-bottom-color: var(--accent);
  }

  /* ═══════════════════════════════════════
     COUNTER
     ═══════════════════════════════════════ */
  #counter {
    position: fixed;
    bottom: 24px;
    right: 32px;
    font-family: var(--font-ui);
    font-size: 13px;
    font-variant-numeric: tabular-nums lining-nums;
    color: var(--text-faint);
    z-index: 200;
    user-select: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #counter.visible {
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     HINT
     ═══════════════════════════════════════ */
  #hint {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-faint);
    z-index: 200;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: hint-in 0.6s ease 1.2s forwards;
    transition: opacity 0.4s ease;
  }

  #hint.hidden {
    opacity: 0 !important;
    animation: none;
  }

  #hint kbd {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 12px;
    line-height: 1;
    padding: 3px 7px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-muted);
  }

  @keyframes hint-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* ═══════════════════════════════════════
     MOBILE
     ═══════════════════════════════════════ */
  @media (max-width: 640px) {
    .slide {
      padding: 32px 24px;
    }

    .points li {
      padding-left: 18px;
    }

    .points li::before {
      width: 5px;
      height: 5px;
    }

    .slide-quote {
      padding-left: 16px;
    }

    .label {
      font-size: 11px;
      padding: 4px 12px;
    }

    .framework {
      gap: 12px;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const progress = document.getElementById('progress')!;
  const counter = document.getElementById('counter')!;
  const hint = document.getElementById('hint')!;
  const total = slides.length;
  let current = 0;
  let hasInteracted = false;

  function init() {
    const hash = parseInt(location.hash.replace('#', ''));
    if (hash > 0 && hash <= total) {
      current = hash - 1;
    }
    show(current);
  }

  function show(index: number) {
    if (index < 0 || index >= total) return;
    current = index;

    slides.forEach((s, i) => {
      if (i === current) {
        s.classList.add('active');
      } else {
        s.classList.remove('active');
      }
    });

    // Progress
    const pct = total > 1 ? (current / (total - 1)) * 100 : 0;
    progress.style.width = `${pct}%`;

    // Counter
    counter.textContent = `${current + 1}\u2009/\u2009${total}`;
    if (current > 0) {
      counter.classList.add('visible');
    } else {
      counter.classList.remove('visible');
    }

    // URL
    history.replaceState(null, '', current === 0 ? location.pathname : `#${current + 1}`);
  }

  function next() {
    if (current < total - 1) show(current + 1);
  }

  function prev() {
    if (current > 0) show(current - 1);
  }

  function dismissHint() {
    if (!hasInteracted) {
      hasInteracted = true;
      hint.classList.add('hidden');
    }
  }

  // Keyboard
  document.addEventListener('keydown', (e) => {
    dismissHint();
    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
      case ' ':
        e.preventDefault();
        next();
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
      case 'Backspace':
        e.preventDefault();
        prev();
        break;
      case 'Home':
        e.preventDefault();
        show(0);
        break;
      case 'End':
        e.preventDefault();
        show(total - 1);
        break;
      case 'f':
      case 'F':
        if (!e.metaKey && !e.ctrlKey) {
          e.preventDefault();
          const el = document.documentElement as any;
          const doc = document as any;
          if (doc.fullscreenElement || doc.webkitFullscreenElement) {
            (doc.exitFullscreen || doc.webkitExitFullscreen).call(doc);
          } else {
            (el.requestFullscreen || el.webkitRequestFullscreen).call(el);
          }
        }
        break;
    }
  });

  // Click to advance (but not on links)
  document.getElementById('deck')!.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'A' || target.closest('a')) return;
    dismissHint();
    next();
  });

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;

  document.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    },
    { passive: true }
  );

  document.addEventListener(
    'touchend',
    (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) < 40 || Math.abs(dy) > Math.abs(dx)) return;
      dismissHint();
      if (dx < 0) next();
      else prev();
    },
    { passive: true }
  );

  init();
</script>
