---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';
import profilePhoto from '../assets/alexander.jpg';
import { sortPosts } from '../utils/format';

const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
---

<BaseLayout title="Alexander Sumer">
  <div class="home-bio">
    <Image src={profilePhoto} alt="Alexander Sumer" class="home-photo" width={88} height={88} />
    <p>
      Hi, I'm Alexander. I write when I get deeply curious about something that matters to me.
      Lately I am focused on taking transformative AI seriously.
    </p>
  </div>

  <nav class="home-links">
    <a href="/resume/">Resume</a>
    <a href="https://www.linkedin.com/in/alexandersumer" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://x.com/xegisunowoumsyq" target="_blank" rel="noopener">X</a>
    <a href="https://www.instagram.com/alexander2357_/" target="_blank" rel="noopener">Instagram</a>
  </nav>

  <h2 class="home-section-title">Writing</h2>
  <PostList posts={posts} />
</BaseLayout>
