---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Alexander Sumer">
  <div class="home-bio">
    <img src="/alexander.jpg" alt="Alexander Sumer" class="home-photo" width="88" height="88" />
    <p>
      Hi, I'm Alexander. I write when I get deeply curious about something that
      matters to me. Lately I am focused on taking transformative AI seriously.
    </p>
  </div>

  <div class="home-links">
    <a href="/resume/">Resume</a>
    <a href="https://www.linkedin.com/in/alexandersumer" target="_blank" rel="noopener">LinkedIn</a>
  </div>

  <h2 class="home-section-title">Writing</h2>
  <PostList posts={posts} />
</BaseLayout>
