---
import SlideLayout from '../../layouts/SlideLayout.astro';
---

<SlideLayout title="How to Use AI Coding Agents Effectively">
  <!-- 1 · Title -->
  <section class="slide slide--center active">
    <div class="slide__inner">
      <h1 class="title" data-reveal style="--d:0">How to Use AI Coding Agents Effectively</h1>
    </div>
  </section>

  <!-- 2 · The problem -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <blockquote class="big-quote" data-reveal style="--d:0">
        Many people use coding agents for a bit, get frustrated, and conclude "they're not good."
      </blockquote>
      <p class="slide__sub" data-reveal style="--d:1">
        That's like picking up a guitar, fumbling through a few chords, and concluding guitars don't
        work.
      </p>
    </div>
  </section>

  <!-- 3 · The insight -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <p class="hero-text" data-reveal style="--d:0">
        The people getting the most out of agents <strong class="accent"
          >aren't using better tools.</strong
        >
      </p>
      <p class="hero-text" data-reveal style="--d:1">
        They built the <strong class="accent">skill</strong> to use them well.
      </p>
    </div>
  </section>

  <!-- 4 · The framework -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <div class="framework">
        <span class="framework__word" data-reveal style="--d:0">Plan</span>
        <span class="framework__dot" data-reveal style="--d:1">&middot;</span>
        <span class="framework__word" data-reveal style="--d:2">Execute</span>
        <span class="framework__dot" data-reveal style="--d:3">&middot;</span>
        <span class="framework__word" data-reveal style="--d:4">Verify</span>
      </div>
      <p class="slide__sub" data-reveal style="--d:5">
        Three fundamentally different activities. Keep them separate.
      </p>
    </div>
  </section>

  <!-- 5 · Plan your sessions -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Plan your sessions</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>For non-trivial work, make the agent write a short <code>plan.md</code></li>
        <li>Interrogate it: assumptions, branches, edge cases, risks, verification, rollback</li>
        <li>Revise until there are no hidden branches</li>
        <li>Then break the approved plan into prompts, executed one by one</li>
      </ul>
    </div>
  </section>

  <!-- 6 · Front-load context -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Context before code</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>First: read the README, understand the test framework, reproduce the problem</li>
        <li>Lead with constraints and context, not implementation details</li>
        <li>All context up front is fine if it's reasoning about the plan, not executing</li>
      </ul>
    </div>
  </section>

  <!-- 7 · Show it what good looks like -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Show it what good looks like</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Clone high-quality OSS repos locally</li>
        <li>Ask for one pattern: errors, tests, jobs, APIs, module boundaries</li>
        <li>Extract before imitation: what transfers, what does not?</li>
        <li>Treat the repo as a reference library</li>
      </ul>
    </div>
  </section>

  <!-- 8 · Encode repeatable patterns -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Encode repeatable patterns</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Some work is the same operation applied to many targets</li>
        <li>
          Two artifacts: a tracking table for state and a skill for durable operating procedure
        </li>
        <li>
          Use skills for migrations, testing protocols, security checks, and review checklists
        </li>
        <li>Any contributor, human or agent, picks up a target and follows the same steps</li>
      </ul>
    </div>
  </section>

  <!-- 9 · Parallelize -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Parallelize your sessions</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Separate writing, reviewing, and fixing</li>
        <li>Use clean review sessions for important changes</li>
        <li>Give each reviewer one job: correctness, security, tests, design</li>
        <li>One concern per session</li>
      </ul>
    </div>
  </section>

  <!-- 10 · Smartest models -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Smarter models are cheaper</h2>
      <p class="hero-text" data-reveal style="--d:2">
        A $0.50 prompt that gets it right is cheaper than five $0.05 prompts that each need fixing.
      </p>
      <p class="slide__note" data-reveal style="--d:3">
        Don't optimize for token cost when the bottleneck is your time.
      </p>
    </div>
  </section>

  <!-- 11 · Context window -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Manage your context window</h2>
      <svg
        class="diagram"
        data-reveal
        style="--d:2"
        viewBox="0 0 600 80"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <clipPath id="bar">
            <rect width="600" height="36" rx="6" y="20"></rect>
          </clipPath>
        </defs>
        <g clip-path="url(#bar)">
          <rect x="0" y="20" width="300" height="36" fill="#2a9d5c"></rect>
          <rect x="300" y="20" width="120" height="36" fill="#c89b2b"></rect>
          <rect x="420" y="20" width="180" height="36" fill="#c44e36"></rect>
        </g>
        <line x1="300" y1="20" x2="300" y2="56" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"
        ></line>
        <line x1="420" y1="20" x2="420" y2="56" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"
        ></line>
        <text
          x="150"
          y="43"
          text-anchor="middle"
          fill="white"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="500">High quality</text
        >
        <text
          x="360"
          y="43"
          text-anchor="middle"
          fill="white"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="500">Compact</text
        >
        <text
          x="510"
          y="43"
          text-anchor="middle"
          fill="white"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="500">Start fresh</text
        >
        <text
          x="0"
          y="14"
          fill="currentColor"
          font-family="Inter Variable, sans-serif"
          font-size="12"
          opacity="0.45">0%</text
        >
        <text
          x="300"
          y="14"
          text-anchor="middle"
          fill="currentColor"
          font-family="Inter Variable, sans-serif"
          font-size="12"
          opacity="0.45">50%</text
        >
        <text
          x="420"
          y="14"
          text-anchor="middle"
          fill="currentColor"
          font-family="Inter Variable, sans-serif"
          font-size="12"
          opacity="0.45">70%</text
        >
        <text
          x="600"
          y="14"
          text-anchor="end"
          fill="currentColor"
          font-family="Inter Variable, sans-serif"
          font-size="12"
          opacity="0.45">100%</text
        >
        <text
          x="300"
          y="74"
          text-anchor="middle"
          fill="currentColor"
          font-family="Inter Variable, sans-serif"
          font-size="11"
          opacity="0.35">context window usage →</text
        >
      </svg>
      <p class="slide__note" data-reveal style="--d:3">
        Compaction loses dead ends, file reads, and failed attempts that still shape every response.
        Break problems down so you never need it.
      </p>
    </div>
  </section>

  <!-- 12 · Verification step -->
  <section class="slide" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <h2 class="heading" data-reveal style="--d:1">Tell the agent how to verify its own work</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>The verification must be automated, deterministic, and runnable</li>
        <li>Ask for a check the agent can execute, then make it run the check</li>
        <li>Review findings need evidence: file, line, contract, and failing path</li>
      </ul>
    </div>
  </section>

  <!-- 13 · Verifiability thesis -->
  <section class="slide slide--center" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <p class="hero-text" data-reveal style="--d:1">
        Agents are only good at things that are <strong class="accent">easy to verify.</strong>
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        Code compiles or it doesn't. Tests pass or they don't. Where verification is hard, agents
        fail quietly.
      </p>
    </div>
  </section>

  <!-- 14 · Test-first -->
  <section class="slide slide--center" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <p class="hero-text" data-reveal style="--d:1">
        A test that has never failed is a test you cannot trust.
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        A smoke detector that has never been near smoke tells you nothing about whether it works.
      </p>
      <p class="slide__note" data-reveal style="--d:3">
        Have the agent introduce a regression and confirm the test actually catches it.
      </p>
    </div>
  </section>

  <!-- 15 · Dev loop -->
  <section class="slide" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <h2 class="heading" data-reveal style="--d:1">Invest in your local dev loop</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Your agent is only as good as your feedback loop</li>
        <li>Reproduce CI locally, run the service e2e locally</li>
        <li>Fast local feedback: lint, type check, unit tests, e2e, security scan</li>
        <li>If CI takes 20 minutes remotely, you're flying blind for 20 minutes</li>
      </ul>
    </div>
  </section>

  <!-- 16 · Security stat -->
  <section class="slide slide--center" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <p class="stat" data-reveal style="--d:1">2.7x</p>
      <h2 class="stat-heading" data-reveal style="--d:2">
        more security vulnerabilities in AI-generated code vs. human-written code.
      </h2>
      <p class="slide__note" data-reveal style="--d:3">
        470 real PRs, human comparison group. The code works. It passes tests. It isn't secure.
      </p>
    </div>
  </section>

  <!-- 17 · Mechanize invariants -->
  <section class="slide" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <h2 class="heading" data-reveal style="--d:1">Mechanize your invariants</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>AGENTS.md guides behavior. CI constrains behavior.</li>
        <li>Lint rules, type checks, tests, security scans, branch protection</li>
        <li>Instructions degrade as context fills. Checks do not rely on attention.</li>
        <li>If a rule can be checked mechanically, put it in the dev loop.</li>
      </ul>
    </div>
  </section>

  <!-- 18 · Bail -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">Know when to bail</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>
          <strong>Context corruption is irreversible.</strong> Failed attempts confuse every subsequent
          turn.
        </li>
        <li>Start a clean session. It takes 30 seconds.</li>
        <li>
          Bail signals: repeats itself, contradicts earlier decisions, suggests rejected fixes
        </li>
      </ul>
    </div>
  </section>

  <!-- 19 · Commit -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">Commit before everything</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Agents move fast and break things across many files at once</li>
        <li>Commit before every major agent operation</li>
        <li><code>git diff</code> between commits is the fastest way to review</li>
        <li>Small commits let you revert a single bad step instead of an entire session</li>
      </ul>
    </div>
  </section>

  <!-- 20 · Continuous refactoring -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">Refactor continuously</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Code generation makes tactical changes cheap</li>
        <li>Tactical changes accumulate complexity</li>
        <li>Run periodic design reviews in read-only mode</li>
        <li>Ask for the smallest change that reduces cognitive load or change amplification</li>
      </ul>
    </div>
  </section>

  <!-- 21 · Design fundamentals -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">The old books still matter</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>APOSD: reduce cognitive load and change amplification</li>
        <li>DDD: preserve domain language and real business distinctions</li>
        <li>Parnas and Brooks: hide information, protect conceptual integrity</li>
      </ul>
    </div>
  </section>

  <!-- 22 · Languages -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">Work in agent-friendly languages</h2>
      <svg
        class="diagram diagram--venn"
        data-reveal
        style="--d:2"
        viewBox="0 0 500 350"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Equilateral layout: side=150, r=100, ~50px overlap per pair -->
        <circle
          cx="250"
          cy="105"
          r="100"
          fill="rgba(74,111,165,0.12)"
          stroke="rgba(74,111,165,0.30)"
          stroke-width="1.5"></circle>
        <circle
          cx="175"
          cy="235"
          r="100"
          fill="rgba(26,122,58,0.12)"
          stroke="rgba(26,122,58,0.30)"
          stroke-width="1.5"></circle>
        <circle
          cx="325"
          cy="235"
          r="100"
          fill="rgba(154,114,0,0.12)"
          stroke="rgba(154,114,0,0.30)"
          stroke-width="1.5"></circle>
        <!-- Labels outside circles -->
        <text
          x="250"
          y="14"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="600"
          fill="currentColor">Type Safety</text
        >
        <text
          x="250"
          y="30"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="10.5"
          fill="currentColor"
          opacity="0.45">compiler catches errors</text
        >
        <text
          x="72"
          y="330"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="600"
          fill="currentColor">Source-Available</text
        >
        <text
          x="72"
          y="346"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="10.5"
          fill="currentColor"
          opacity="0.45">reads actual code</text
        >
        <text
          x="428"
          y="330"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="13"
          font-weight="600"
          fill="currentColor">Popularity</text
        >
        <text
          x="428"
          y="346"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="10.5"
          fill="currentColor"
          opacity="0.45">training data</text
        >
        <!-- Center intersection -->
        <text
          x="250"
          y="196"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="16"
          font-weight="700"
          fill="var(--accent)">TS, Go</text
        >
        <!-- Two-circle intersections -->
        <text
          x="212"
          y="170"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="11.5"
          fill="currentColor"
          opacity="0.4">Rust, Zig</text
        >
        <text
          x="288"
          y="170"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="11.5"
          fill="currentColor"
          opacity="0.4">Kotlin, C#</text
        >
        <text
          x="250"
          y="248"
          text-anchor="middle"
          font-family="Inter Variable, sans-serif"
          font-size="11.5"
          fill="currentColor"
          opacity="0.4">Python, JS</text
        >
      </svg>
    </div>
  </section>

  <!-- 23 · Expert amplifier -->
  <section class="slide slide--center" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <p class="hero-text" data-reveal style="--d:1">
        The agent does the typing.<br />The human does the <strong class="accent">judgment.</strong>
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        An agent refactors your database access layer. It compiles, passes tests, looks clean. A
        senior engineer sees it opens a new connection per query instead of using the pool.
      </p>
    </div>
  </section>

  <!-- 24 · Agent context limits -->
  <section class="slide slide--center" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <p class="hero-text" data-reveal style="--d:1">
        The agent is only as good as the <strong class="accent">context you give it.</strong>
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        Production error rates spike. The agent reviews logs, finds sidecars returning 5xx, and
        calls it the root cause. The real cause: a hard limit of 24 nodes, CPUs maxed, no room to
        scale. The agent had zero infrastructure context. It found a symptom, not the cause.
      </p>
    </div>
  </section>

  <!-- 25 · Curious generalist -->
  <section class="slide slide--center" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <p class="hero-text" data-reveal style="--d:1">
        Agents supply depth on demand.<br />The <strong class="accent">curious generalist</strong> directs
        it.
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        Knowing what problems to solve, what questions to ask, and whether the answer is right.
        Across many domains, not just one.
      </p>
    </div>
  </section>

  <!-- 26 · Limits -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Meta-Skills</span>
      <h2 class="heading" data-reveal style="--d:1">Know when NOT to use agents</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>
          Pricing logic across products, admin permissions, infrastructure teardown. Anywhere subtle
          context spans many steps.
        </li>
        <li>High cost of failure + hard to verify = do it yourself</li>
        <li>
          Agents are confident and fast. If you can't verify quickly, that confidence works against
          you.
        </li>
      </ul>
    </div>
  </section>

  <!-- 27 · End -->
  <section class="slide slide--center slide--end">
    <div class="slide__inner">
      <p class="end-text" data-reveal style="--d:0">Read the full post</p>
      <a
        class="end-link"
        href="/blog/how-to-use-ai-coding-agents-effectively"
        data-reveal
        style="--d:1">alexandersumer.com/blog/how-to-use-ai-coding-agents-effectively</a
      >
    </div>
  </section>
</SlideLayout>

<style>
  /* ═══════════════════════════════════════
     TITLE SLIDE
     ═══════════════════════════════════════ */
  .title {
    font-family: var(--font-ui);
    font-size: clamp(36px, 5.5vw, 58px);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: var(--heading);
  }

  /* ═══════════════════════════════════════
     HERO TEXT
     ═══════════════════════════════════════ */
  .hero-text {
    font-family: var(--font-ui);
    font-size: clamp(24px, 3.2vw, 38px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--heading);
    margin-bottom: 8px;
  }

  .hero-text:last-of-type {
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════
     FRAMEWORK
     ═══════════════════════════════════════ */
  .framework {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .framework__word {
    font-family: var(--font-ui);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--heading);
    line-height: 1;
  }

  .framework__dot {
    font-size: clamp(32px, 5vw, 56px);
    color: var(--accent);
    line-height: 1;
    font-weight: 300;
  }

  /* ═══════════════════════════════════════
     SECTION LABEL
     ═══════════════════════════════════════ */
  .label {
    display: block;
    width: fit-content;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--lc, var(--accent));
    background: color-mix(in srgb, var(--lc, var(--accent)) 10%, transparent);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  [data-section='planning'] .label {
    --lc: var(--c-planning);
  }
  [data-section='execution'] .label {
    --lc: var(--c-execution);
  }
  [data-section='verification'] .label {
