---
import SlideLayout from '../../layouts/SlideLayout.astro';
---

<SlideLayout title="How to Use AI Coding Agents Effectively">
  <!-- 1 · Title -->
  <section class="slide slide--center active">
    <div class="slide__inner">
      <h1 class="title" data-reveal style="--d:0">How to Use AI Coding Agents Effectively</h1>
    </div>
  </section>

  <!-- 2 · The problem -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <blockquote class="big-quote" data-reveal style="--d:0">
        Many people use coding agents for a bit, get frustrated, and conclude "they're not good."
      </blockquote>
      <p class="slide__sub" data-reveal style="--d:1">
        That's like picking up a guitar, fumbling through a few chords, and concluding guitars don't
        work.
      </p>
    </div>
  </section>

  <!-- 3 · The insight -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <p class="hero-text" data-reveal style="--d:0">
        The people getting the most out of agents
        <strong class="accent">aren't using better tools.</strong>
      </p>
      <p class="hero-text" data-reveal style="--d:1">
        They built the <strong class="accent">skill</strong> to use them well.
      </p>
    </div>
  </section>

  <!-- 4 · The framework -->
  <section class="slide slide--center">
    <div class="slide__inner">
      <div class="framework">
        <span class="framework__word" data-reveal style="--d:0">Plan</span>
        <span class="framework__dot" data-reveal style="--d:1">&middot;</span>
        <span class="framework__word" data-reveal style="--d:2">Execute</span>
        <span class="framework__dot" data-reveal style="--d:3">&middot;</span>
        <span class="framework__word" data-reveal style="--d:4">Review</span>
        <span class="framework__dot" data-reveal style="--d:5">&middot;</span>
        <span class="framework__word" data-reveal style="--d:6">Verify</span>
      </div>
      <p class="slide__sub" data-reveal style="--d:7">
        Different jobs. Different contexts. Different artifacts.
      </p>
    </div>
  </section>

  <!-- 5 · The stack -->
  <section class="slide slide--center" data-section="fundamentals">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">101</span>
      <div class="stack" data-reveal style="--d:1">
        <span>Model</span>
        <span>Agent</span>
        <span>Tools</span>
        <span>Workspace</span>
        <span>Checks</span>
      </div>
      <p class="slide__sub" data-reveal style="--d:2">
        Know which layer you are changing before you blame the agent.
      </p>
    </div>
  </section>

  <!-- 6 · Models -->
  <section class="slide" data-section="fundamentals">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Models</span>
      <h2 class="heading" data-reveal style="--d:1">Choose models by risk</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Use stronger reasoning for ambiguous, unfamiliar, expensive work</li>
        <li>Use faster models for cheap, reversible, mechanical work</li>
        <li>Switch when the task changes</li>
      </ul>
    </div>
  </section>

  <!-- 7 · Agent surfaces -->
  <section class="slide" data-section="fundamentals">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Surfaces</span>
      <h2 class="heading" data-reveal style="--d:1">Choose the right surface</h2>
      <ul class="points" data-reveal style="--d:2">
        <li><strong>IDE:</strong> direct edits with tight human steering</li>
        <li><strong>CLI:</strong> repo, shell, and Atlassian context</li>
        <li><strong>Chat:</strong> explanation without a real feedback loop</li>
      </ul>
    </div>
  </section>

  <!-- 8 · Tools and context -->
  <section class="slide" data-section="fundamentals">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Context</span>
      <h2 class="heading" data-reveal style="--d:1">Give the agent safe reach</h2>
      <ul class="points" data-reveal style="--d:2">
        <li><strong>MCP:</strong> tools and data without copy-paste</li>
        <li><strong>Skills and memory:</strong> instructions that survive the chat</li>
        <li><strong>AI Gateway:</strong> model access for internal AI features</li>
      </ul>
    </div>
  </section>

  <!-- 9 · Workspace -->
  <section class="slide" data-section="fundamentals">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Workspace</span>
      <h2 class="heading" data-reveal style="--d:1">Run where checks are real</h2>
      <ul class="points" data-reveal style="--d:2">
        <li><strong>Local:</strong> fastest when setup already works</li>
        <li><strong>Volt:</strong> useful when environment setup is the hard part</li>
        <li><strong>Worktrees:</strong> isolate parallel attempts</li>
      </ul>
    </div>
  </section>

  <!-- 10 · Planning artifact -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Create a planning artifact</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>For non-trivial work, write the plan before code</li>
        <li>Capture goal, scope, sequence, checks, risks, rollback point</li>
        <li>Record what proves each step worked</li>
        <li>Make it readable by a fresh session or teammate</li>
      </ul>
    </div>
  </section>

  <!-- 11 · Interrogate the plan -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Red-team the plan</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Walk every branch before execution</li>
        <li>What assumptions are you making?</li>
        <li>What alternatives did you reject?</li>
        <li>What edge cases are missing?</li>
      </ul>
    </div>
  </section>

  <!-- 12 · Steel threads -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Chunk by steel thread</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Don't chunk by layer</li>
        <li>Database → API → UI creates an integration cliff</li>
        <li>Pick one thin path through the real system</li>
        <li>Verify it before widening it</li>
      </ul>
    </div>
  </section>

  <!-- 13 · Steel thread examples -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">A steel thread is agent-shaped</h2>
      <ul class="points" data-reveal style="--d:2">
        <li><strong>Migration:</strong> move one operation, leave the rest alone</li>
        <li><strong>Greenfield:</strong> one narrow happy path that persists</li>
        <li><strong>Review:</strong> one behavior, one diff, one risk surface</li>
        <li><strong>Verify:</strong> one real path the agent can run</li>
      </ul>
    </div>
  </section>

  <!-- 14 · Give concrete context -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Give concrete context</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>README, tests, nearby code</li>
        <li>The problem reproduced locally</li>
        <li>Sibling implementations</li>
        <li>Good repo examples when a pattern matters</li>
      </ul>
    </div>
  </section>

  <!-- 15 · Worked example -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Example</span>
      <h2 class="heading" data-reveal style="--d:1">Turn a vague ask into a steel thread</h2>
      <ul class="points" data-reveal style="--d:2">
        <li><strong>Bad:</strong> "Refactor auth"</li>
        <li><strong>Plan:</strong> inspect one route, policy check, and test seam</li>
        <li><strong>Build:</strong> change one behavior behind one reviewed diff</li>
        <li><strong>Prove:</strong> run the failing test, auth test, lint, and fresh review</li>
      </ul>
    </div>
  </section>

  <!-- 16 · Encode repeatable patterns -->
  <section class="slide" data-section="planning">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Planning</span>
      <h2 class="heading" data-reveal style="--d:1">Encode repeatable patterns</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Some work repeats across many targets</li>
        <li>Tracking table: what is done</li>
        <li>Skill: how to do one target</li>
        <li>The table tracks state. The skill preserves judgment.</li>
      </ul>
    </div>
  </section>

  <!-- 17 · Separate context by job -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Separate context by job</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Keep the main session clean</li>
        <li>Use subagents for narrow jobs</li>
        <li>Review from fresh context</li>
        <li>One concern per context</li>
      </ul>
    </div>
  </section>

  <!-- 18 · Smarter models -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Do not optimize for token cost</h2>
      <p class="hero-text" data-reveal style="--d:2">
        A $0.50 prompt that gets it right is cheaper than five $0.05 prompts that each need fixing.
      </p>
      <p class="slide__note" data-reveal style="--d:3">
        Use strong models when mistakes are expensive.
      </p>
    </div>
  </section>

  <!-- 19 · Do not fight polluted context -->
  <section class="slide" data-section="execution">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Execution</span>
      <h2 class="heading" data-reveal style="--d:1">Do not fight polluted context</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Compact before quality drops</li>
        <li>Start fresh when the task changes</li>
        <li>Bail when the agent repeats itself</li>
        <li>Preserve clean context for judgment</li>
      </ul>
    </div>
  </section>

  <!-- 20 · Tell it how to verify -->
  <section class="slide" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <h2 class="heading" data-reveal style="--d:1">Tell it how to verify</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Do not just say "refactor this"</li>
        <li>Name the exact check the agent should run</li>
        <li>Make it show the result</li>
        <li>Verification must be automated, deterministic, and runnable</li>
      </ul>
    </div>
  </section>

  <!-- 21 · Separate writing from review -->
  <section class="slide" data-section="review">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Review</span>
      <h2 class="heading" data-reveal style="--d:1">Separate writing from review</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Do not make the writing session the only reviewer</li>
        <li>Start a clean review session</li>
        <li>Give it the diff, relevant files, and conventions</li>
        <li>Ask for file, line, contract, and failing path</li>
      </ul>
    </div>
  </section>

  <!-- 22 · Split review by job -->
  <section class="slide" data-section="review">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Review</span>
      <h2 class="heading" data-reveal style="--d:1">Split review by job</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Correctness</li>
        <li>Failure modes</li>
        <li>Security</li>
        <li>Tests</li>
        <li>Design</li>
      </ul>
      <p class="slide__note" data-reveal style="--d:3">One reviewer, one lens.</p>
    </div>
  </section>

  <!-- 23 · Functional is not secure -->
  <section class="slide" data-section="review">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Review</span>
      <h2 class="heading" data-reveal style="--d:1">Passing tests does not prove secure</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Working code can still create attack surface</li>
        <li>Add security as a separate review lens</li>
        <li>Scan every PR</li>
        <li>Treat auth, data access, and input handling as high-risk</li>
      </ul>
    </div>
  </section>

  <!-- 24 · Test-first -->
  <section class="slide slide--center" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <p class="hero-text" data-reveal style="--d:1">
        A test that has never failed is a test you cannot trust.
      </p>
      <p class="slide__sub" data-reveal style="--d:2">
        A smoke detector that has never been near smoke tells you nothing about whether it works.
      </p>
    </div>
  </section>

  <!-- 25 · Mechanize invariants -->
  <section class="slide" data-section="verification">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Verification</span>
      <h2 class="heading" data-reveal style="--d:1">Mechanize invariants</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Instructions guide judgment</li>
        <li>Checks enforce invariants</li>
        <li>Lint, type checks, tests, security scans, branch protection</li>
        <li>If a rule can be checked mechanically, put it in the dev loop</li>
      </ul>
    </div>
  </section>

  <!-- 26 · Human judgment -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Judgment</span>
      <h2 class="heading" data-reveal style="--d:1">The human owns judgment</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Decide what context matters</li>
        <li>Name the behavior you want</li>
        <li>Reject plausible nonsense</li>
        <li>Protect design boundaries and domain language</li>
      </ul>
    </div>
  </section>

  <!-- 27 · Limits -->
  <section class="slide" data-section="meta">
    <div class="slide__inner">
      <span class="label" data-reveal style="--d:0">Judgment</span>
      <h2 class="heading" data-reveal style="--d:1">Slow down when verification is weak</h2>
      <ul class="points" data-reveal style="--d:2">
        <li>Context spans multiple systems</li>
        <li>Correctness depends on subtle behavior</li>
        <li>The cost of failure is high</li>
        <li>Tests do not cover the real risk</li>
      </ul>
    </div>
  </section>

  <!-- 28 · End -->
  <section class="slide slide--center slide--end">
    <div class="slide__inner">
      <p class="hero-text" data-reveal style="--d:0">
        The agent does the typing. The human owns judgment.
      </p>
      <p class="end-text" data-reveal style="--d:1">Verification keeps both honest.</p>
      <a
        class="end-link"
        href="/blog/how-to-use-ai-coding-agents-effectively"
        data-reveal
        style="--d:2">alexandersumer.com/blog/how-to-use-ai-coding-agents-effectively</a
      >
    </div>
  </section>
</SlideLayout>

<style>
  /* ═══════════════════════════════════════
     TITLE SLIDE
     ═══════════════════════════════════════ */
  .title {
    font-family: var(--font-ui);
    font-size: clamp(36px, 5.5vw, 58px);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: var(--heading);
  }

  /* ═══════════════════════════════════════
     STACK
     ═══════════════════════════════════════ */
  .stack {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .stack span {
    font-family: var(--font-ui);
    font-size: clamp(18px, 2.4vw, 26px);
    font-weight: 650;
    color: var(--heading);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    border-radius: 999px;
    padding: 10px 18px;
  }

  /* ═══════════════════════════════════════
     HERO TEXT
     ═══════════════════════════════════════ */
  .hero-text {
    font-family: var(--font-ui);
    font-size: clamp(24px, 3.2vw, 38px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--heading);
    margin-bottom: 8px;
  }

  .hero-text:last-of-type {
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════
     FRAMEWORK
     ═══════════════════════════════════════ */
  .framework {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .framework__word {
    font-family: var(--font-ui);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--heading);
    line-height: 1;
  }

  .framework__dot {
    font-size: clamp(32px, 5vw, 56px);
    color: var(--accent);
    line-height: 1;
    font-weight: 300;
  }

  /* ═══════════════════════════════════════
     SECTION LABEL
     ═══════════════════════════════════════ */
  .label {
    display: block;
    width: fit-content;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--lc, var(--accent));
    background: color-mix(in srgb, var(--lc, var(--accent)) 10%, transparent);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  [data-section='fundamentals'] .label {
    --lc: var(--c-fundamentals);
  }
  [data-section='planning'] .label {
    --lc: var(--c-planning);
  }
  [data-section='execution'] .label {
    --lc: var(--c-execution);
  }
  [data-section='verification'] .label {
    --lc: var(--c-verification);
  }
  [data-section='review'] .label {
    --lc: var(--c-review);
  }
  [data-section='meta'] .label {
    --lc: var(--c-meta);
  }

  /* ═══════════════════════════════════════
     HEADINGS
     ═══════════════════════════════════════ */
  .heading {
    font-family: var(--font-ui);
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--heading);
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════
     POINTS
     ═══════════════════════════════════════ */
  .points {
    list-style: none;
    padding: 0;
  }

  .points li {
    font-family: var(--font-ui);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 400;
    line-height: 1.6;
    color: var(--text);
    padding: 8px 0 8px 24px;
    position: relative;
  }

  .points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lc, var(--accent));
    opacity: 0.5;
  }

  .points li em {
    color: var(--text-muted);
    font-style: italic;
  }

  .points li strong {
    font-weight: 600;
    color: var(--heading);
  }

  .points li code {
    font-family: 'SF Mono', 'Fira Code', Consolas, monospace;
    font-size: 0.88em;
    background: var(--code-bg);
    padding: 2px 7px;
    border-radius: 4px;
  }

  /* ═══════════════════════════════════════
     QUOTES
     ═══════════════════════════════════════ */
  .big-quote {
    font-family: var(--font-ui);
    font-size: clamp(24px, 3vw, 34px);
    font-style: italic;
    line-height: 1.5;
    color: var(--heading);
    margin-bottom: 28px;
  }

  .big-quote::before {
    content: none;
  }

  .slide-quote {
    font-family: var(--font-ui);
    font-size: clamp(19px, 2.2vw, 24px);
    font-style: italic;
    line-height: 1.6;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    margin: 0 0 20px;
  }

  /* ═══════════════════════════════════════
     STAT
     ═══════════════════════════════════════ */
  .stat {
    font-family: var(--font-ui);
    font-size: clamp(80px, 16vw, 160px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .stat-heading {
    font-family: var(--font-ui);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--heading);
    margin-bottom: 20px;
  }

  /* ═══════════════════════════════════════
     SUPPORTING TEXT
     ═══════════════════════════════════════ */
  .slide__sub {
    font-family: var(--font-ui);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 640px;
  }

  .slide--center .slide__sub {
    margin-left: auto;
    margin-right: auto;
  }

  .slide__note {
    font-family: var(--font-ui);
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════
     ACCENT
     ═══════════════════════════════════════ */
  .accent {
    color: var(--accent);
  }

  /* ═══════════════════════════════════════
     END SLIDE
     ═══════════════════════════════════════ */
  .end-text {
    font-family: var(--font-ui);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--heading);
    margin-bottom: 20px;
  }

  .end-link {
    font-family: var(--font-ui);
    font-size: clamp(15px, 1.6vw, 18px);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    padding-bottom: 2px;
    transition: border-color 0.2s ease;
    cursor: pointer;
    user-select: text;
  }

  .end-link:hover {
    border-bottom-color: var(--accent);
  }

